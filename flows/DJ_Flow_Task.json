{
  "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "name": "DJ_Flow_Task",
    "description": "Document Journey - Task step flow. Sends styled email and Adaptive Card with 'Mark Complete' button to assignees via Teams, waits for completion, checks CompletionRule, updates DJ_StepHistory, and advances the journey.",
    "version": "2.0.0"
  },
  "parameters": {
    "SharePointSiteUrl": {
      "type": "String",
      "defaultValue": ""
    },
    "SearchSiteUrl": {
      "type": "String",
      "defaultValue": "",
      "metadata": { "description": "SharePoint site URL for the search/tasks hub" }
    },
    "StepHistoryListName": {
      "type": "String",
      "defaultValue": "DJ_StepHistory"
    },
    "HistoryListName": {
      "type": "String",
      "defaultValue": "DJ_History"
    }
  },
  "triggers": {
    "manual": {
      "type": "Request",
      "kind": "Http",
      "inputs": {
        "schema": {
          "type": "object",
          "properties": {
            "historyId": { "type": "integer" },
            "stepOrder": { "type": "integer" },
            "stepType": { "type": "string" },
            "stepName": { "type": "string" },
            "documentUrl": { "type": "string" },
            "documentName": { "type": "string" },
            "journeyName": { "type": "string" },
            "siteUrl": { "type": "string" }
          },
          "required": ["historyId", "stepOrder"]
        }
      }
    }
  },
  "actions": {
    "Get_Step_History_Record": {
      "type": "ApiConnection",
      "runAfter": {},
      "inputs": {
        "host": { "connection": { "name": "@parameters('$connections')['sharepointonline']['connectionId']" } },
        "method": "get",
        "path": "/datasets/@{encodeURIComponent(parameters('SharePointSiteUrl'))}/tables/@{encodeURIComponent(parameters('StepHistoryListName'))}/items",
        "queries": {
          "$filter": "HistoryId eq @{triggerBody()?['historyId']} and StepOrder eq @{triggerBody()?['stepOrder']}"
        }
      }
    },
    "Get_History_Record_For_Email": {
      "type": "ApiConnection",
      "runAfter": { "Get_Step_History_Record": ["Succeeded"] },
      "inputs": {
        "host": { "connection": { "name": "@parameters('$connections')['sharepointonline']['connectionId']" } },
        "method": "get",
        "path": "/datasets/@{encodeURIComponent(parameters('SharePointSiteUrl'))}/tables/@{encodeURIComponent(parameters('HistoryListName'))}/items/@{triggerBody()?['historyId']}"
      }
    },
    "Send_Email_Task_Assigned": {
      "type": "ApiConnection",
      "runAfter": { "Get_History_Record_For_Email": ["Succeeded"] },
      "inputs": {
        "host": { "connection": { "name": "@parameters('$connections')['office365']['connectionId']" } },
        "method": "post",
        "path": "/v2/Mail",
        "body": {
          "To": "@{body('Get_Step_History_Record')?['value']?[0]?['AssignedTo']?['Email']}",
          "Subject": "New Task: @{triggerBody()?['journeyName']} - @{triggerBody()?['stepName']}",
          "Body": "<div style=\"font-family:'Segoe UI',Arial,sans-serif; max-width:600px; margin:0 auto; color:#333\"><table role=\"presentation\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"margin:0 0 12px 0\"><tr><td style=\"background:#2ea3a0; color:#fff; font-weight:600; padding:4px 12px; border-radius:9999px; font-size:14px; line-height:18px; display:inline-block\">New Task</td></tr></table><p><strong>You have a new assigned task.</strong><br>Please review and complete the assigned task by the due date.</p><table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"border:1px solid #ddd; border-radius:6px; margin-top:10px\"><tr><td style=\"background:#f4f4f4; font-size:16px; font-weight:600; padding:14px; border-bottom:1px solid #ddd\">Task Details</td></tr><tr><td style=\"padding:16px\"><table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\"><tr><td style=\"padding:5px 0; vertical-align:top; width:160px\">Task Name:</td><td style=\"padding:5px 0; vertical-align:top\"><strong>@{triggerBody()?['stepName']}</strong></td></tr><tr><td colspan=\"2\" style=\"height:20px; line-height:20px\">&nbsp;</td></tr><tr><td style=\"padding:5px 0; vertical-align:top\">Journey:</td><td style=\"padding:5px 0; vertical-align:top\">@{triggerBody()?['journeyName']}</td></tr><tr><td style=\"padding:5px 0; vertical-align:top\">Document:</td><td style=\"padding:5px 0; vertical-align:top\"><a href=\"@{triggerBody()?['documentUrl']}\" style=\"color:#2ea3a0\">@{triggerBody()?['documentName']}</a></td></tr><tr><td style=\"padding:5px 0; vertical-align:top\">Site:</td><td style=\"padding:5px 0; vertical-align:top\"><a href=\"@{triggerBody()?['siteUrl']}\" style=\"color:#2ea3a0\">@{triggerBody()?['siteUrl']}</a></td></tr><tr><td colspan=\"2\" style=\"height:20px; line-height:20px\">&nbsp;</td></tr><tr><td style=\"padding:5px 0; vertical-align:top\">Task Owner:</td><td style=\"padding:5px 0; vertical-align:top\">@{body('Get_History_Record_For_Email')?['InitiatedBy']?['Title']}</td></tr><tr><td title=\"Created On date and time\" style=\"padding:5px 0; vertical-align:top\">Task Created:</td><td style=\"padding:5px 0; vertical-align:top\">@{formatDateTime(utcNow(), 'dd/MM/yyyy hh:mm tt')}</td></tr><tr><td style=\"padding:5px 0; vertical-align:top\">Assigned To:</td><td style=\"padding:5px 0; vertical-align:top\">@{body('Get_Step_History_Record')?['value']?[0]?['AssignedTo']?['Title']}</td></tr><tr><td title=\"Due Date\" style=\"padding:5px 0; vertical-align:top\">Due Date:</td><td style=\"padding:5px 0; vertical-align:top\">@{if(empty(body('Get_Step_History_Record')?['value']?[0]?['DueDate']), 'No due date', formatDateTime(body('Get_Step_History_Record')?['value']?[0]?['DueDate'], 'dd/MM/yyyy'))}</td></tr></table></td></tr><tr><td style=\"background:#f4f4f4; font-size:16px; font-weight:600; padding:14px; border-bottom:1px solid #ddd; border-top:1px solid #ddd\">Action Required</td></tr><tr><td style=\"padding:16px\"><table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\"><tr><td style=\"padding:5px 0; vertical-align:top; width:160px\">Status:</td><td style=\"padding:5px 0; vertical-align:top\">In Progress</td></tr><tr><td style=\"padding:5px 0; vertical-align:top\">How to Complete:</td><td style=\"padding:5px 0; vertical-align:top\">Open the Adaptive Card sent to you in Microsoft Teams and click 'Mark Complete'.</td></tr></table></td></tr></table><div style=\"margin:30px 0\">To view all your tasks: <a href=\"@{parameters('SearchSiteUrl')}/SitePages/Tasks.aspx\" style=\"color:#2ea3a0\">Click here</a></div><hr style=\"border:none; border-top:1px solid #eee; margin:24px 0\"><p style=\"color:#666\"><i>This is an automated notification. Do not reply to this email.<br>If you believe you received this in error, contact the task owner.</i></p></div>",
          "IsHtml": true
        }
      }
    },
    "Post_Task_Card_to_Teams": {
      "type": "ApiConnection",
      "runAfter": { "Get_History_Record_For_Email": ["Succeeded"] },
      "inputs": {
        "host": { "connection": { "name": "@parameters('$connections')['teams']['connectionId']" } },
        "method": "post",
        "path": "/v1.0/teams/adaptivecards/wait",
        "body": {
          "recipient": {
            "to": "@{body('Get_Step_History_Record')?['value']?[0]?['AssignedTo']?['Email']}"
          },
          "messageBody": "{\"type\":\"AdaptiveCard\",\"$schema\":\"http://adaptivecards.io/schemas/adaptive-card.json\",\"version\":\"1.4\",\"body\":[{\"type\":\"TextBlock\",\"text\":\"Task Assigned\",\"weight\":\"Bolder\",\"size\":\"Medium\"},{\"type\":\"TextBlock\",\"text\":\"@{triggerBody()?['journeyName']} - @{triggerBody()?['stepName']}\",\"wrap\":true},{\"type\":\"TextBlock\",\"text\":\"Document: @{triggerBody()?['documentName']}\",\"wrap\":true},{\"type\":\"Input.Text\",\"id\":\"comments\",\"placeholder\":\"Add comments (optional)\",\"isMultiline\":true}],\"actions\":[{\"type\":\"Action.Submit\",\"title\":\"Mark Complete\",\"data\":{\"action\":\"Completed\"}}]}",
          "updateMessage": "Task completed"
        }
      }
    },
    "Update_Step_Completed": {
      "type": "ApiConnection",
      "runAfter": { "Post_Task_Card_to_Teams": ["Succeeded"] },
      "inputs": {
        "host": { "connection": { "name": "@parameters('$connections')['sharepointonline']['connectionId']" } },
        "method": "patch",
        "path": "/datasets/@{encodeURIComponent(parameters('SharePointSiteUrl'))}/tables/@{encodeURIComponent(parameters('StepHistoryListName'))}/items/@{body('Get_Step_History_Record')?['value']?[0]?['ID']}",
        "body": {
          "Status": "Completed",
          "ActionDate": "@{utcNow()}",
          "Comments": "@{body('Post_Task_Card_to_Teams')?['data']?['comments']}"
        }
      }
    },
    "Get_History_Record": {
      "type": "ApiConnection",
      "runAfter": { "Update_Step_Completed": ["Succeeded"] },
      "inputs": {
        "host": { "connection": { "name": "@parameters('$connections')['sharepointonline']['connectionId']" } },
        "method": "get",
        "path": "/datasets/@{encodeURIComponent(parameters('SharePointSiteUrl'))}/tables/@{encodeURIComponent(parameters('HistoryListName'))}/items/@{triggerBody()?['historyId']}"
      }
    },
    "Check_If_Journey_Complete": {
      "type": "If",
      "runAfter": { "Get_History_Record": ["Succeeded"] },
      "expression": {
        "and": [
          { "greaterOrEquals": ["@triggerBody()?['stepOrder']", "@body('Get_History_Record')?['TotalSteps']"] }
        ]
      },
      "actions": {
        "Mark_Journey_Completed": {
          "type": "ApiConnection",
          "inputs": {
            "host": { "connection": { "name": "@parameters('$connections')['sharepointonline']['connectionId']" } },
            "method": "patch",
            "path": "/datasets/@{encodeURIComponent(parameters('SharePointSiteUrl'))}/tables/@{encodeURIComponent(parameters('HistoryListName'))}/items/@{triggerBody()?['historyId']}",
            "body": {
              "Status": "Completed",
              "CompletedDate": "@{utcNow()}"
            }
          }
        },
        "Send_Journey_Completed_Email": {
          "type": "ApiConnection",
          "runAfter": { "Mark_Journey_Completed": ["Succeeded"] },
          "inputs": {
            "host": { "connection": { "name": "@parameters('$connections')['office365']['connectionId']" } },
            "method": "post",
            "path": "/v2/Mail",
            "body": {
              "To": "@{body('Get_History_Record')?['InitiatedBy']?['Email']}",
              "Subject": "Journey Completed: @{triggerBody()?['journeyName']} - @{triggerBody()?['documentName']}",
              "Body": "<div style=\"font-family:'Segoe UI',Arial,sans-serif; max-width:600px; margin:0 auto; color:#333\"><table role=\"presentation\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"margin:0 0 12px 0\"><tr><td style=\"background:#107c10; color:#fff; font-weight:600; padding:4px 12px; border-radius:9999px; font-size:14px; line-height:18px; display:inline-block\">Journey Complete</td></tr></table><p><strong>A document journey you initiated has been completed.</strong><br>All steps have been successfully finished.</p><table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"border:1px solid #ddd; border-radius:6px; margin-top:10px\"><tr><td style=\"background:#f4f4f4; font-size:16px; font-weight:600; padding:14px; border-bottom:1px solid #ddd\">Journey Summary</td></tr><tr><td style=\"padding:16px\"><table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\"><tr><td style=\"padding:5px 0; vertical-align:top; width:160px\">Journey:</td><td style=\"padding:5px 0; vertical-align:top\"><strong>@{triggerBody()?['journeyName']}</strong></td></tr><tr><td style=\"padding:5px 0; vertical-align:top\">Document:</td><td style=\"padding:5px 0; vertical-align:top\"><a href=\"@{triggerBody()?['documentUrl']}\" style=\"color:#107c10\">@{triggerBody()?['documentName']}</a></td></tr><tr><td colspan=\"2\" style=\"height:20px; line-height:20px\">&nbsp;</td></tr><tr><td style=\"padding:5px 0; vertical-align:top\">Total Steps:</td><td style=\"padding:5px 0; vertical-align:top\">@{body('Get_History_Record')?['TotalSteps']}</td></tr><tr><td style=\"padding:5px 0; vertical-align:top\">Completed:</td><td style=\"padding:5px 0; vertical-align:top\">@{formatDateTime(utcNow(), 'dd/MM/yyyy hh:mm tt')}</td></tr></table></td></tr></table><div style=\"margin:30px 0\">To view all your journeys: <a href=\"@{parameters('SearchSiteUrl')}/SitePages/Tasks.aspx\" style=\"color:#107c10\">Click here</a></div><hr style=\"border:none; border-top:1px solid #eee; margin:24px 0\"><p style=\"color:#666\"><i>This is an automated notification. Do not reply to this email.<br>If you believe you received this in error, contact the journey initiator.</i></p></div>",
              "IsHtml": true
            }
          }
        }
      },
      "else": {
        "actions": {
          "Advance_Journey": {
            "type": "ApiConnection",
            "inputs": {
              "host": { "connection": { "name": "@parameters('$connections')['sharepointonline']['connectionId']" } },
              "method": "patch",
              "path": "/datasets/@{encodeURIComponent(parameters('SharePointSiteUrl'))}/tables/@{encodeURIComponent(parameters('HistoryListName'))}/items/@{triggerBody()?['historyId']}",
              "body": {
                "CurrentStepOrder": "@{add(triggerBody()?['stepOrder'], 1)}"
              }
            }
          },
          "Get_Next_Step": {
            "type": "ApiConnection",
            "runAfter": { "Advance_Journey": ["Succeeded"] },
            "inputs": {
              "host": { "connection": { "name": "@parameters('$connections')['sharepointonline']['connectionId']" } },
              "method": "get",
              "path": "/datasets/@{encodeURIComponent(parameters('SharePointSiteUrl'))}/tables/@{encodeURIComponent(parameters('StepHistoryListName'))}/items",
              "queries": {
                "$filter": "HistoryId eq @{triggerBody()?['historyId']} and StepOrder eq @{add(triggerBody()?['stepOrder'], 1)}"
              }
            }
          },
          "Trigger_Next_Step_Flow": {
            "type": "Http",
            "runAfter": { "Get_Next_Step": ["Succeeded"] },
            "inputs": {
              "method": "POST",
              "uri": "REPLACE_WITH_NEXT_STEP_FLOW_URL",
              "body": {
                "historyId": "@{triggerBody()?['historyId']}",
                "stepOrder": "@{add(triggerBody()?['stepOrder'], 1)}",
                "stepType": "@{body('Get_Next_Step')?['value']?[0]?['StepType']}",
                "stepName": "@{body('Get_Next_Step')?['value']?[0]?['StepName']}",
                "documentUrl": "@{triggerBody()?['documentUrl']}",
                "documentName": "@{triggerBody()?['documentName']}",
                "journeyName": "@{triggerBody()?['journeyName']}",
                "siteUrl": "@{triggerBody()?['siteUrl']}"
              },
              "retryPolicy": {
                "type": "exponential",
                "count": 3,
                "interval": "PT5S",
                "maximumInterval": "PT2M"
              }
            }
          }
        }
      }
    },
    "Response": {
      "type": "Response",
      "runAfter": { "Check_If_Journey_Complete": ["Succeeded"] },
      "inputs": {
        "statusCode": 200,
        "body": { "status": "completed" }
      }
    }
  }
}
